{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "japanese",
  "includeGitInstructions": true,
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(pnpm add:*)",
      "Bash(npx prisma:*)",
      "Bash(pnpm install:*)",
      "Bash(npx tsx:*)",
      "Bash(rm:*)",
      "Bash(pnpm type-check:*)",
      "Bash(pnpm turbo:*)",
      "Bash(pnpm build)",
      "Bash(npx tsc:*)",
      "Bash(find:*)",
      "Bash(npm run build:*)",
      "mcp__ide__getDiagnostics",
      "Bash(npm run typecheck:*)",
      "Bash(npm run:*)",
      "Bash(mkdir:*)",
      "Bash(supabase:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(npx supabase:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm prisma:generate:*)",
      "Bash(pnpm exec prisma:*)",
      "Bash(ls:*)",
      "Bash(pnpm dev:*)",
      "Bash(ln:*)",
      "Bash(pnpm --filter web build)",
      "Bash(pnpm run:*)",
      "Bash(chmod:*)",
      "Bash(npx next build:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(pnpm prisma migrate:*)",
      "Bash(pnpm lint:*)",
      "Bash(mv:*)",
      "Bash(pnpm prisma:studio:*)",
      "Bash(pnpm prisma:migrate:create:*)",
      "Bash(pnpm supabase:start:*)",
      "Bash(sed:*)",
      "Bash(pnpm --filter @repo/features build)",
      "Bash(pnpm exec tsc:*)",
      "Bash(tree:*)",
      "Bash(pnpm remove:*)",
      "Bash(pnpm check-types:*)",
      "Bash(pnpm generate:*)",
      "Bash(pnpm prisma generate:*)",
      "Bash(pnpm tsc:*)",
      "Bash(pnpm migrate:dev:*)",
      "Bash(pnpm tsx:*)",
      "Bash(true)",
      "Bash(pnpm:*)",
      "Bash(sh:*)",
      "Bash(cp:*)",
      "Bash(git diff:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "companyAnnouncements": [
    "プロジェクト方針は AGENTS.md / CLAUDE.md と .cursor/rules を参照してください。",
    "個人用設定はこの settings.json に統合しています。"
  ],
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "vercel"
  ]
}
